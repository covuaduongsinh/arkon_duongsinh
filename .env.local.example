# ============================================================
# Arkon — Local development environment
# cp .env.local.example .env.local
# Requires: PostgreSQL, Redis, MinIO running on localhost
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://arkon:arkon_secret@localhost:5432/arkon

# --- Auth (JWT) ---
SECRET_KEY=change-me-to-a-random-secret-string

# --- MCP token hashing ---
# HMAC pepper for hashing MCP bearer tokens at rest. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# Rotating this value invalidates EVERY existing MCP token — set once and keep stable.
MCP_TOKEN_PEPPER=change-me-to-a-random-pepper

# --- Default Admin Account ---
DEFAULT_ADMIN_EMAIL=admin@arkon.local
DEFAULT_ADMIN_PASSWORD=admin123

# --- Secret hardening ---
# Placeholder SECRET_KEY / MCP_TOKEN_PEPPER / DEFAULT_ADMIN_PASSWORD only warn by
# default. In production set real values, then enable enforcement:
# REQUIRE_SECURE_SECRETS=true

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=arkon-files
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_HOURS=24

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
WORKER_MAX_JOBS=3
WORKER_JOB_TIMEOUT=600

# --- CORS ---
CORS_ORIGINS=*

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5055
